def slugify(s):
    if not s: return ""
    s = str(s).lower()
    rep = {'ı': 'i', 'İ': 'i', 'ü': 'u', 'ö': 'o', 'ş': 's', 'ç': 'c', 'ğ': 'g', 'â': 'a'}
    for old, new in rep.items():
        s = s.replace(old, new)
    return re.sub(r'[^a-z0-9\s]', '', s).strip()

